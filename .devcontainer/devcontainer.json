{
  "name": "AnalogGym Dev Container",
  "build": {
    "dockerfile": "../docker/Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace/AnalogGym",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace/AnalogGym,type=bind"
  ],
  "settings": {
    "python.defaultInterpreterPath": "/usr/bin/python3"
  },
  "extensions": [
    "ms-python.python"
  ],
  "postCreateCommand": "pip3 install --upgrade pip"
}